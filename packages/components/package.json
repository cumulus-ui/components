{
  "name": "@cumulus-ui/components",
  "version": "0.0.1",
  "description": "Web components inspired by Cloudscape Design System and Rainforest",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run clean && npm run build:esm && npm run build:types",
    "build:esm": "esbuild src/index.ts --bundle --format=esm --outfile=dist/index.js --external:lit --external:lit/* --external:@lit/context --external:@lit/context/*",
    "build:cdn": "esbuild src/index.ts --bundle --format=esm --outfile=dist/cumulus-ui.cdn.js --minify",
    "build:types": "tsc --emitDeclarationOnly",
    "dev": "node scripts/build-demo.mjs && node scripts/serve.mjs",
    "dev:watch": "node scripts/build-demo.mjs --watch & node scripts/serve.mjs",
    "build:demo": "node scripts/build-demo.mjs",
    "test": "npm run build:cdn && npx playwright test",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.demo.json",
    "typecheck:watch": "tsc --noEmit --watch",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "web-components",
    "lit",
    "cloudscape",
    "design-system"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@cloudscape-design/design-tokens": "^3.0.78",
    "@cloudscape-design/global-styles": "^1.0.56",
    "@cloudscape-design/theming-runtime": "^1.0.106",
    "@floating-ui/dom": "^1.7.6",
    "@lit/context": "^1.1.6",
    "lit": "^3.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.2",
    "@types/pngjs": "^6.0.5",
    "esbuild": "^0.28.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "typescript": "~5.7.0",
    "vite": "^8.0.5"
  }
}
