{
  "name": "@cumulus-ui/test-utils",
  "version": "0.0.1",
  "description": "Test utilities for @cumulus-ui/components",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./dom": {
      "types": "./dist/dom/index.d.ts",
      "default": "./dist/dom/index.js"
    },
    "./selectors": {
      "types": "./dist/selectors/index.d.ts",
      "default": "./dist/selectors/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "license": "Apache-2.0",
  "peerDependencies": {
    "@cumulus-ui/components": "^0.0.1"
  },
  "devDependencies": {
    "typescript": "~5.7.0"
  }
}
