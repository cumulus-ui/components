{
  "name": "@cumulus-ui/components",
  "version": "0.0.1",
  "description": "Web components inspired by Cloudscape Design System and Rainforest",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "web-components",
    "lit",
    "cloudscape",
    "design-system"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/cumulus-ui/components.git"
  },
  "dependencies": {
    "lit": "^3.2.0"
  },
  "devDependencies": {
    "typescript": "~5.7.0"
  }
}
