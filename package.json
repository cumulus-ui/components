{
  "name": "@cumulus-ui/components",
  "version": "0.6.4",
  "description": "Web components inspired by Cloudscape Design System",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run clean && npm run build:esm && npm run build:types",
    "build:esm": "node scripts/build.mjs esm",
    "build:cdn": "node scripts/build.mjs cdn",
    "build:types": "tsc -p tsconfig.build.json",
    "build:demo": "node scripts/build-demo.mjs",
    "dev": "npx vite --port 3000",
    "unit": "vitest run",
    "test": "npm run build:cdn && npx playwright test",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "generate:interfaces": "tsx scripts/generate-interfaces.ts",
    "generate:styles": "tsx scripts/generate-styles.ts",
    "capture:baselines": "cd scripts/cloudscape-baselines && npm ci && npx tsx capture.ts"
  },
  "keywords": [
    "web-components",
    "lit",
    "cloudscape",
    "design-system"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/cumulus-ui/components.git"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "@lit/context": "^1.1.6",
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@cloudscape-design/code-view": "^3.0.118",
    "@cloudscape-design/components": "^3.0.1270",
    "@cumulus-ui/design-tokens": "^0.4.4",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@types/pngjs": "^6.0.5",
    "ace-code": "^1.43.6",
    "esbuild": "^0.28.0",
    "esbuild-plugin-minify-html-literals": "^3.0.0",
    "jsdom": "^29.0.2",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "ace-code": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "ace-code": {
      "optional": true
    }
  }
}
