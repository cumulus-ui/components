{
  "name": "@cumulus-ui/components",
  "version": "0.0.1",
  "description": "Web components inspired by Cloudscape Design System and Rainforest",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run clean && npm run build:esm && npm run build:types",
    "build:esm": "esbuild src/index.ts --bundle --format=esm --outfile=dist/index.js --external:lit --external:lit/*",
    "build:cdn": "esbuild src/index.ts --bundle --format=esm --outfile=dist/cumulus-ui.cdn.js --minify",
    "build:types": "tsc --emitDeclarationOnly",
    "dev": "npm run build:cdn && node scripts/serve.mjs",
    "test": "npm run build:cdn && npx playwright test",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "web-components",
    "lit",
    "cloudscape",
    "design-system"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/cumulus-ui/components.git"
  },
  "dependencies": {
    "lit": "^3.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "esbuild": "^0.28.0",
    "typescript": "~5.7.0"
  }
}
